{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/health",
      "schedule": "0 12 * * 1,4"
    }
  ],
  "redirects": [
    {
      "source": "/vi/plans-pricing-access",
      "destination": "/plans-pricing-access",
      "permanent": false
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.jurassicenglish.com" }],
      "destination": "https://jurassicenglish.com/:path",
      "permanent": true
    },
    { "source": "/student-academy/",          "destination": "/student-academy",          "permanent": true },
    { "source": "/interactive-demo/",         "destination": "/interactive-demo",         "permanent": true },
    { "source": "/book-diagnostic/",          "destination": "/book-diagnostic",          "permanent": true },
    { "source": "/digital-reasoning-engine/", "destination": "/digital-reasoning-engine", "permanent": true },
    { "source": "/evidence/",                 "destination": "/evidence",                 "permanent": true },
    { "source": "/school-framework/",         "destination": "/school-framework",         "permanent": true }
  ],
  "rewrites": [
    { "source": "/student-academy",                                  "destination": "https://je-ecosystem-landing-preview.vercel.app/student-academy" },
    { "source": "/student-academy/:path*",                           "destination": "https://je-ecosystem-landing-preview.vercel.app/student-academy/:path*" },
    { "source": "/school-framework",                                 "destination": "https://je-ecosystem-landing-preview.vercel.app/school-framework" },
    { "source": "/school-framework/:path*",                          "destination": "https://je-ecosystem-landing-preview.vercel.app/school-framework/:path*" },
    { "source": "/digital-reasoning-engine",                         "destination": "https://je-ecosystem-landing-preview.vercel.app/digital-reasoning-engine" },
    { "source": "/digital-reasoning-engine/:path*",                  "destination": "https://je-ecosystem-landing-preview.vercel.app/digital-reasoning-engine/:path*" },
    { "source": "/interactive-demo",                                 "destination": "https://je-ecosystem-landing-preview.vercel.app/interactive-demo" },
    { "source": "/interactive-demo/:path*",                          "destination": "https://je-ecosystem-landing-preview.vercel.app/interactive-demo/:path*" },
    { "source": "/evidence",                                         "destination": "https://je-ecosystem-landing-preview.vercel.app/evidence" },
    { "source": "/evidence/:path*",                                  "destination": "https://je-ecosystem-landing-preview.vercel.app/evidence/:path*" },
    { "source": "/book-diagnostic",                                  "destination": "https://je-ecosystem-landing-preview.vercel.app/book-diagnostic" },
    { "source": "/book-diagnostic/:path*",                           "destination": "https://je-ecosystem-landing-preview.vercel.app/book-diagnostic/:path*" },
    { "source": "/_next/:path*",                                     "destination": "https://je-ecosystem-landing-preview.vercel.app/_next/:path*" },
    { "source": "/images/student-academy-page/:path*",               "destination": "https://je-ecosystem-landing-preview.vercel.app/images/student-academy-page/:path*" },

    { "source": "/c856412889f27af2/:path*",                          "destination": "https://je-ecosystem-landing-preview.vercel.app/c856412889f27af2/:path*" },
    { "source": "/425f0745123b9f56/:path*",                          "destination": "https://je-ecosystem-landing-preview.vercel.app/425f0745123b9f56/:path*" },

    { "source": "/api/internal/approval-action", "destination": "/api/internal/pilot-requests/approval-action/confirm" },
    { "source": "/pilot/:path*", "destination": "/index.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/health.ts":                        { "maxDuration": 5  },
    "api/verify-pricing-access.ts":         { "maxDuration": 5  },
    "api/verify-external-portal-access.ts": { "maxDuration": 5  },
    "api/generate-pricing-access-link.ts":  { "maxDuration": 5  },
    "api/internal/pilot-requests.ts":       { "maxDuration": 10 },
    "api/internal/pilot-requests/[submissionId].ts": { "maxDuration": 10 },
    "api/internal/pilot-requests/[submissionId]/[action].ts": { "maxDuration": 10 },
    "api/get-started.ts":                   { "maxDuration": 10 },
    "api/pricing-registration.ts":          { "maxDuration": 15 },
    "api/inspect-notion-lead.ts":           { "maxDuration": 10 },
    "api/update-notion-je-leads-schema.ts": { "maxDuration": 10 },
    "api/generate-image.ts":               { "maxDuration": 25 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://db.onlinewebfonts.com https://fonts.googleapis.com; font-src 'self' https://db.onlinewebfonts.com https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co https://api.resend.com https://vitals.vercel-insights.com https://va.vercel-scripts.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    },
    {
      "source": "/plans-pricing-access(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/external/pilot(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/internal/pilot-requests(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/pilot/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/api/health",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=30, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/(student-academy|interactive-demo|book-diagnostic|digital-reasoning-engine|evidence|school-framework)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/(student-academy|interactive-demo|book-diagnostic|digital-reasoning-engine|evidence|school-framework)/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/((?!assets|api|images|student-academy|interactive-demo|book-diagnostic|digital-reasoning-engine|evidence|school-framework).*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
