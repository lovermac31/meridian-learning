{
  "name": "jurassic-english",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host=0.0.0.0",
    "dev:server": "tsx server.ts",
    "build": "vite build && node --import tsx scripts/prerender-route-metadata.mjs",
    "start": "NODE_ENV=production tsx server.ts",
    "preview": "vite preview",
    "test:metadata": "node --import tsx --test tests/metadata.test.ts",
    "validate:prerender": "node --import tsx scripts/validate-prerender-routes.mjs",
    "pricing:access-link": "node scripts/generate-pricing-access-link.mjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.16",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
