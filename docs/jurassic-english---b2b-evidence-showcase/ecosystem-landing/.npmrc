# Required because @botui/react@1.1.5 declares react@^18.2.0 as a peer.
# This Next.js workspace runs on react@19; the production root Vite app
# runs the same packages on react@19 successfully, so the install is safe.
# Without this flag, Vercel's strict `npm install` aborts on the peer
# range mismatch.
legacy-peer-deps=true
