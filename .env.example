# --- Server-Side Environment Variables ---
# These are used by the Express server (server.ts) and Vercel serverless functions.
# They are NEVER exposed to the client-side React bundle.

# GEMINI_API_KEY: Required for AI image generation via the Creative Studio.
# Get yours at https://ai.google.dev/
# For local development, copy this file to .env.local and set your real key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RESEND_API_KEY: Required for public intake acceptance.
# If omitted, form endpoints return a safe temporary-unavailable response.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"

# GET_STARTED_NOTIFY_EMAIL: Optional destination for Get Started notifications.
# Example: info@jurassicenglish.com
GET_STARTED_NOTIFY_EMAIL="info@jurassicenglish.com"

# GET_STARTED_FROM_EMAIL: Optional sender address for notification emails.
# Must be a verified sender/domain in your Resend account.
GET_STARTED_FROM_EMAIL="Jurassic English <onboarding@jurassicenglish.com>"

# PRICING_NOTIFY_EMAIL: Reserved for a future split notification path.
# Current pricing registration notifications use GET_STARTED_NOTIFY_EMAIL.
PRICING_NOTIFY_EMAIL="info@jurassicenglish.com"

# PRICING_FROM_EMAIL: Reserved for a future split notification path.
# Current pricing registration notifications use GET_STARTED_FROM_EMAIL.
PRICING_FROM_EMAIL="Jurassic English <onboarding@jurassicenglish.com>"

# PRICING_ACCESS_SIGNING_SECRET: Required for secure private Plans & Pricing access links.
# Use a long random value (at least 32 characters) and keep it server-side only.
PRICING_ACCESS_SIGNING_SECRET="replace-with-a-long-random-secret"

# EXTERNAL_PORTAL_SIGNING_SECRET: Required for external pilot portal access links.
# Use a distinct long random value (at least 32 characters) and keep it server-side only.
EXTERNAL_PORTAL_SIGNING_SECRET="replace-with-a-long-random-external-portal-secret"

# Legacy shared operator key.
# Temporary rollout fallback only. Replace with scoped keys below, then remove this.
PRICING_ACCESS_OPERATOR_KEY="replace-with-a-long-random-legacy-operator-key"

# Scoped operator keys.
# Use distinct long random values (at least 24 characters each).
PRICING_ACCESS_LINK_OPERATOR_KEY="replace-with-a-long-random-link-operator-key"
INTERNAL_PORTAL_OPERATOR_KEY="replace-with-a-long-random-internal-operator-key"
NOTION_LEAD_INSPECT_OPERATOR_KEY="replace-with-a-long-random-inspect-operator-key"
NOTION_SCHEMA_OPERATOR_KEY="replace-with-a-long-random-schema-operator-key"

# Optional operator IP allowlists.
# Comma-separated exact client IPs. If omitted, no IP allowlist is enforced.
OPERATOR_IP_ALLOWLIST=""
PRICING_ACCESS_LINK_OPERATOR_IP_ALLOWLIST=""
INTERNAL_PORTAL_OPERATOR_IP_ALLOWLIST=""
NOTION_LEAD_INSPECT_OPERATOR_IP_ALLOWLIST=""
NOTION_SCHEMA_OPERATOR_IP_ALLOWLIST=""

# NOTION_TOKEN: Notion internal integration token for the JE CRM write path.
# Create an internal integration at https://www.notion.so/profile/integrations
# Grant it access to the JE Leads database (share the database with the integration).
# Token format: secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TOKEN="secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# NOTION_JE_LEADS_DB_ID: The 32-character ID of the JE Leads Notion database.
# Find it in the database page URL:
#   https://www.notion.so/{workspace}/{DATABASE_ID}?v=...
# Paste only the 32-character hex segment — hyphens optional.
NOTION_JE_LEADS_DB_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Supabase server-side write path ---
#
# These values are used only by Vercel serverless functions in api/.
# Do not add VITE_, NEXT_PUBLIC_, PUBLIC_, or other client-exposed prefixes to
# privileged Supabase credentials.

# SUPABASE_URL: The REST endpoint for the WorldWise Learning / Jurassic English Supabase project.
# Format: https://<project-ref>.supabase.co
SUPABASE_URL="https://hvuohtenmsqlsqrbgveg.supabase.co"

# SUPABASE_WRITE_KEY: Preferred backend-only write key for server-side inserts.
# Accepted values:
#   - new opaque secret key: sb_secret_...
#   - legacy service_role JWT
# Accepted fallback env names, in order:
#   - SUPABASE_SECRET_KEY
#   - SUPABASE_SERVICE_ROLE_KEY
# NEVER use SUPABASE_ANON_KEY or sb_publishable_* for backend write storage.
# NEVER expose this key to the client bundle, browser, logs, chat, or Git.
SUPABASE_WRITE_KEY="sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx"

# CRON_SECRET: Required in production for scheduled maintenance endpoints such
# as /api/supabase-keepalive. Set this in Vercel Project Settings → Environment
# Variables. Vercel Cron sends it as Authorization: Bearer <CRON_SECRET>.
# Generate with: openssl rand -hex 32
CRON_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional public/read-safe Supabase keys:
# None are currently required. The browser must not write directly to JE lead tables.

# PORT: The port the Express server listens on (local dev only; Vercel ignores this).
PORT=3001

# --- Phase 2.1A — Durable rate limiting (Upstash Redis) ---
#
# When ENABLE_DURABLE_RATE_LIMIT is unset or "false", the existing per-instance
# in-memory rate-limit store is used (Phase 0 behaviour, unchanged). When set
# to "true", checkRateLimit() routes through Upstash Redis via its REST API.
# Falls back to the in-memory store with a warning if the URL/TOKEN below are
# missing.
#
# Per-route failMode determines behaviour when Upstash itself errors out:
#   - 'closed' (default for mutations): deny the request — abuse resistance
#     during the outage outweighs lost legitimate traffic.
#   - 'open' (low-risk reads only): allow the request through.
ENABLE_DURABLE_RATE_LIMIT="false"

# UPSTASH_REDIS_REST_URL: The HTTPS REST endpoint for the Upstash Redis database.
# Format: https://<region>-<name>-<digits>.upstash.io
UPSTASH_REDIS_REST_URL=""

# UPSTASH_REDIS_REST_TOKEN: Bearer token. Server-side only. Never expose to client.
UPSTASH_REDIS_REST_TOKEN=""

# Optional: key prefix shared by all counters (helps when one Redis is reused
# across environments). Defaults to "je:rl:".
UPSTASH_RATELIMIT_KEY_PREFIX="je:rl:"

# Optional: per-call Upstash timeout (ms). Defaults to 1500.
UPSTASH_RATELIMIT_TIMEOUT_MS="1500"

# --- Phase 2.2A — Staged CORS allowlist (API routes only) ---
#
# Defense-in-depth allowlist for API responses. Same-origin requests are
# unaffected — they have no Origin header and the helper passes through
# without setting any Access-Control-* header.
#
# Defaults baked into api/_lib/corsSecurity.ts (no env required):
#   https://jurassicenglish.com
#   https://www.jurassicenglish.com
#
# API_CORS_ALLOWED_ORIGINS: extra origins, comma-separated. Use full origins
# with scheme. Example:
#   "https://partner-school.edu,https://staging.jurassicenglish.com"
API_CORS_ALLOWED_ORIGINS=""

# API_CORS_ALLOW_VERCEL_PREVIEWS: when "true", any *.vercel.app preview
# origin is allowed. Useful during preview-deployment smoke tests; should be
# unset (default) or "false" on the production environment.
API_CORS_ALLOW_VERCEL_PREVIEWS="false"

# NODE_ENV: Set automatically by hosting platforms. Do not change for local dev.
# NODE_ENV=production
