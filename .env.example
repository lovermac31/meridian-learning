# --- Server-Side Environment Variables ---
# These are used by the Express server (server.ts) and Vercel serverless functions.
# They are NEVER exposed to the client-side React bundle.

# GEMINI_API_KEY: Required for AI image generation via the Creative Studio.
# Get yours at https://ai.google.dev/
# For local development, copy this file to .env.local and set your real key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RESEND_API_KEY: Optional for Get Started email notifications.
# If omitted, intake submissions are still accepted and logged safely.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"

# GET_STARTED_NOTIFY_EMAIL: Optional destination for Get Started notifications.
# Example: info@jurassicenglish.com
GET_STARTED_NOTIFY_EMAIL="info@jurassicenglish.com"

# GET_STARTED_FROM_EMAIL: Optional sender address for notification emails.
# Must be a verified sender/domain in your Resend account.
GET_STARTED_FROM_EMAIL="Jurassic English <onboarding@jurassicenglish.com>"

# PORT: The port the Express server listens on (local dev only; Vercel ignores this).
PORT=3001

# NODE_ENV: Set automatically by hosting platforms. Do not change for local dev.
# NODE_ENV=production
